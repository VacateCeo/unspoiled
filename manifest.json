{
  "manifest_version": 3,
  "name": "Unspoiled",
  "version": "0.1.0",
  "description": "Blocks TV and movie spoilers on social media using AI-powered semantic detection.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.youtube.com/*",
    "https://api.themoviedb.org/*",
    "https://image.tmdb.org/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.youtube.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Unspoiled"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/welcome.html"],
      "matches": ["<all_urls>"]
    }
  ]
}